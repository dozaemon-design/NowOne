# ─────────────────────────────
# WordPress プロジェクト全体を除外
# テーマ（NowOne）のみを Git 管理
# ─────────────────────────────

# まず全部除外
/*

# 必要なものだけ許可
!.gitignore

!/.github/

!/acf-json/
!/css/
!/font/
# assets 配下すべて許可
!/assets/
!/assets/**
# build artifacts (CIで生成するためコミットしない)
/assets/build/
/assets/build/**
# inc 配下すべて許可
!/inc/
!/inc/**
# template-parts 配下すべて許可
!/template-parts/
!/template-parts/**

# build / tooling
!/package.json
!/package-lock.json
!/pnpm-lock.yaml
!/yarn.lock
!/vite.config.*
!/tsconfig.json
!/.nvmrc

# sources
!/src/
!/src/**

# PHP テンプレート
!/*.php

# テーマ主要ファイル
!/style.css
!/README.md
!/LICENSE
!/screenshot.png

# macOS ゴミは絶対に除外
.DS_Store
**/.DS_Store

# .AppleDouble .LSOverride対策
._*
**/._*
